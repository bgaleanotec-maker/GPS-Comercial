# === GPS Comercial - Variables de Entorno ===
# Copiar este archivo como .env y configurar los valores

# Flask
SECRET_KEY=cambiar-por-una-clave-segura-aleatoria

# Base de datos (PostgreSQL en produccion)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Traccar GPS Server (DigitalOcean)
TRACCAR_URL=http://64.227.85.213:8082
TRACCAR_USER=admin
TRACCAR_PASSWORD=tu-password-de-traccar

# SendGrid Email
SENDGRID_API_KEY=SG.tu-api-key-aqui
MAIL_DEFAULT_SENDER=tu-email@dominio.com
SST_EMAIL_RECIPIENT=destinatario-sst@dominio.com

# Admin inicial (solo para init_db.py)
ADMIN_INITIAL_PASSWORD=cambiar-password-seguro

# Worker de fondo (true/false)
ENABLE_BACKGROUND_WORKER=true
